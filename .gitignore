# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# backend (NestJS)：依赖、构建产物与覆盖率（与 `backend/.gitignore` 一致，便于在仓库根目录统一可见）
backend/node_modules/
backend/dist/
backend/coverage/
backend/*.tsbuildinfo

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
