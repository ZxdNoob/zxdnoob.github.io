{
  "name": "zxdnoob",
  "version": "0.0.8",
  "private": true,
  "description": "ZxdNoob 个人博客：Next.js App Router + NestJS API + SQLite。脚本说明：dev=前端开发；build=生产构建；build:static=静态导出(out/)供 GitHub Pages；dev:api/build:api/start:api=子目录 backend；lint/format 与 husky+lint-staged 在提交前格式化。",
  "scripts": {
    "prepare": "husky",
    "dev": "next dev",
    "build": "next build",
    "build:static": "STATIC_EXPORT=1 next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:api": "npm run start:dev --prefix backend",
    "build:api": "npm run build --prefix backend",
    "start:api": "npm run start:prod --prefix backend"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json,css,md,yml,yaml}": [
      "prettier --write"
    ],
    "backend/**/*.{ts,js,json,md,yml,yaml}": [
      "prettier --write --config backend/prettier.config.mjs --ignore-path backend/.prettierignore"
    ]
  },
  "dependencies": {
    "github-slugger": "^2.0.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remark-slug": "^8.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  }
}
